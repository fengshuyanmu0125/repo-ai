# ============================================================
# OpenClaw 云服务器部署配置
# 使用方法：cp .env.example .env  然后填写真实值
# ============================================================

# ── LLM / Claude ─────────────────────────────────────────────
ANTHROPIC_AUTH_TOKEN=sk-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_BASE_URL=https://llm.ai-nebula.com

# ── 飞书 Feishu ───────────────────────────────────────────────
# 飞书机器人 App ID & Secret（发消息用）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 日报推送目标（用户 open_id 或群 chat_id）
FEISHU_RECEIVE_ID=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Gateway 鉴权 ──────────────────────────────────────────────
# 生成方式：openssl rand -hex 24
GATEWAY_TOKEN=your_random_gateway_token_here

# ── 第三方数据 ────────────────────────────────────────────────
# Finnhub API Key（免费注册：https://finnhub.io）
FINNHUB_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Tiingo API Token（免费注册：https://www.tiingo.com）
# 用于加密货币、盘后数据等
TIINGO_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 日报配置 ──────────────────────────────────────────────────
# 日报每组显示股票数量
TOP_N=10
